(function() {
    // 1. СТИЛИ (Оформление футера и окна принятия правил)
    const style = document.createElement('style');
    style.innerHTML = `
        /* Футер */
        .dm-universal-footer {
            position: fixed; bottom: 0; left: 0; width: 100%; 
            background: rgba(13, 17, 23, 0.95); color: #8b949e; 
            text-align: center; padding: 10px 0; font-family: -apple-system, sans-serif; 
            font-size: 11px; z-index: 9999; backdrop-filter: blur(5px);
            border-top: 1px solid #30363d;
        }
        .dm-universal-footer a { color: #58a6ff; text-decoration: none; margin: 0 10px; font-weight: bold; }

        /* Окно согласия (Overlay) */
        #dm-legal-consent {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.9); z-index: 10000; display: flex;
            align-items: center; justify-content: center; backdrop-filter: blur(10px);
        }
        .dm-consent-box {
            background: #161b22; color: #c9d1d9; padding: 30px; border-radius: 12px;
            max-width: 500px; width: 90%; border: 1px solid #30363d; text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }
        .dm-consent-box h2 { color: #58a6ff; margin-top: 0; }
        .dm-consent-box p { font-size: 14px; line-height: 1.5; text-align: left; }
        .dm-btn {
            background: #238636; color: white; border: none; padding: 12px 30px;
            border-radius: 6px; cursor: pointer; font-weight: bold; margin-top: 20px;
            transition: background 0.2s;
        }
        .dm-btn:hover { background: #2ea043; }
        .warning-red { color: #f85149; font-weight: bold; }
    `;
    document.head.appendChild(style);

    // 2. ФУНКЦИЯ ПРОВЕРКИ СОГЛАСИЯ
    function checkConsent() {
        if (!localStorage.getItem('dm_legal_accepted')) {
            showConsentModal();
        }
    }

    // 3. СОЗДАНИЕ ОКНА ПРИНЯТИЯ ПРАВИЛ
    function showConsentModal() {
        const modal = document.createElement('div');
        modal.id = 'dm-legal-consent';
        modal.innerHTML = `
            <div class="dm-consent-box">
                <h2>Nutzungsbedingungen</h2>
                <p>Willkommen bei den Projekten von <b>Maksym Didukh</b>. Vor der Nutzung bestätigen Sie bitte:</p>
                <p>
                    • <b>Inhalte:</b> Sie verstehen, dass Zeichnungen и Nachrichten dauerhaft gespeichert werden.<br>
                    • <b>Haftung:</b> Der Betreiber haftet nicht für externe Inhalte (iFrames), auch wenn diese unzensiert (18+) sind.<br>
                    • <b>Datenschutz:</b> Sie akzeptieren die Verarbeitung technischer Daten durch Netlify.
                </p>
                <p class="warning-red">Mit dem Klicken auf "Akzeptieren" bestätigen Sie die Einhaltung der Regeln.</p>
                <button class="dm-btn" id="accept-dm-legal">Akzeptieren & Fortfahren</button>
            </div>
        `;
        document.body.appendChild(modal);

        document.getElementById('accept-dm-legal').onclick = function() {
            localStorage.setItem('dm_legal_accepted', 'true');
            modal.remove();
        };
    }

    // 4. ДОБАВЛЕНИЕ ФУТЕРА
    const currentTitle = document.title || "Project";
    const footer = document.createElement('footer');
    footer.className = 'dm-universal-footer';
    footer.innerHTML = `
        &copy; 2026 Maksym Didukh | <b>${currentTitle}</b> | 
        <a href="https://dmamax.netlify.app/impressum" target="_blank">Impressum</a> | 
        <a href="https://dmamax.netlify.app/datenschutz" target="_blank">Datenschutz</a>
    `;
    document.body.appendChild(footer);

    // Запуск
    checkConsent();
})();
